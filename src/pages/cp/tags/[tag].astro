---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const problems = await getCollection('cp');
  const tags = [...new Set(problems.flatMap(p => p.data.tags))];
  return tags.map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allProblems = await getCollection('cp');

const problems = allProblems
  .filter(p => p.data.tags.includes(tag))
  .sort((a, b) => Number(a.data.difficulty) - Number(b.data.difficulty));

const platformGroups = problems.reduce((acc, p) => {
  const platform = p.data.platform;
  if (!acc[platform]) acc[platform] = [];
  acc[platform].push(p);
  return acc;
}, {} as Record<string, typeof problems>);

const verdictColor: Record<string, string> = {
  AC: 'text-emerald-600 dark:text-emerald-400',
  WA: 'text-red-500',
  TLE: 'text-amber-500',
  MLE: 'text-violet-500',
};
---

<Base
  title={'#' + tag + ' — CP · Shahed Ali'}
  description={'All CP problems tagged with ' + tag + '.'}
>
  <div class="max-w-2xl mx-auto px-6 py-16">

    <a href="/cp/tags" class="inline-flex items-center gap-1.5 text-[13px] text-ink-muted hover:text-ink transition-colors mb-12 group">
      <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      All tags
    </a>

    <div class="mb-10 opacity-0 animate-fade-up" style="animation-fill-mode: forwards;">
      <h1 class="text-[28px] font-medium tracking-tight text-ink mb-2">#{tag}</h1>
      <p class="text-[14px] text-ink-muted">{problems.length} problem{problems.length !== 1 ? 's' : ''}</p>
    </div>

    {Object.entries(platformGroups).map(([platform, probs]) => (
      <div class="mb-10">
        <div class="text-[11px] uppercase tracking-widest font-medium text-ink-faint mb-4">{platform}</div>
        <div class="divide-y divide-border">
          {probs.map((problem, i) => {
            const parts = problem.slug.split('/');
            const platformSlug = parts[0];
            const slug = parts[1];
            return (
              <a
                href={'/cp/' + platformSlug + '/' + slug}
                class="reveal group flex items-center justify-between gap-4 py-4 hover:bg-surface-secondary -mx-3 px-3 rounded-lg transition-colors"
                style={'transition-delay: ' + (i * 40) + 'ms'}
              >
                <div class="flex items-center gap-4 min-w-0">
                  <span class="text-[12px] font-mono text-ink-faint shrink-0 w-12">
                    {problem.data.difficulty}
                  </span>
                  <div class="text-[14px] font-medium text-ink group-hover:text-accent transition-colors truncate">
                    {problem.data.problemName}
                  </div>
                </div>
                <span class={verdictColor[problem.data.verdict] + ' text-[11px] font-medium shrink-0'}>
                  {problem.data.verdict}
                </span>
              </a>
            );
          })}
        </div>
      </div>
    ))}

  </div>
</Base>