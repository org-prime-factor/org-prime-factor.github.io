---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const problems = await getCollection('cp');

const platformIcons: Record<string, string> = {
  Codeforces: '⬡',
  LeetCode: '◈',
  AtCoder: '◎',
  CodeChef: '◇',
};
const platformColors: Record<string, string> = {
  Codeforces: 'bg-blue-500/10 text-blue-500',
  LeetCode: 'bg-amber-500/10 text-amber-500',
  AtCoder: 'bg-emerald-500/10 text-emerald-500',
  CodeChef: 'bg-violet-500/10 text-violet-500',
};

const platformMap = problems.reduce((acc, p) => {
  const platform = p.data.platform;
  if (!acc[platform]) acc[platform] = [];
  acc[platform].push(p);
  return acc;
}, {} as Record<string, typeof problems>);

const tagMap = problems.reduce((acc, p) => {
  p.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagMap).sort((a, b) => b[1] - a[1]);

// --- Build-time CF topic distribution ---
const BANDS = [
  { label: '800 – 1200',  min: 800,  max: 1200 },
  { label: '1300 – 1600', min: 1300, max: 1600 },
  { label: '1700 – 1900', min: 1700, max: 1900 },
  { label: '2000 – 2200', min: 2000, max: 2200 },
  { label: '2300 – 2600', min: 2300, max: 2600 },
  { label: '2700+',       min: 2700, max: Infinity },
];
const TOP_N = 12;

type BandData = {
  label: string;
  count: number;
  tags: { name: string; count: number; weight: number }[];
};

let cfBands: BandData[] = [];
let cfFetchError = false;

try {
  const res = await fetch('https://codeforces.com/api/problemset.problems');
  const { status, result } = await res.json();

  if (status === 'OK') {
    cfBands = BANDS.map(band => {
      const filtered = (result.problems as any[]).filter(
        p => p.rating >= band.min && p.rating <= band.max && p.tags?.length
      );

      const tagCount: Record<string, number> = {};
      filtered.forEach(p => {
        p.tags.forEach((t: string) => {
          tagCount[t] = (tagCount[t] || 0) + 1;
        });
      });

      const sorted = Object.entries(tagCount)
        .sort((a, b) => b[1] - a[1])
        .slice(0, TOP_N);

      const maxCount = sorted[0]?.[1] || 1;

      return {
        label: band.label,
        count: filtered.length,
        tags: sorted.map(([name, count]) => ({
          name,
          count,
          weight: Math.round((0.45 + 0.55 * (count / maxCount)) * 100) / 100,
        })),
      };
    });
  } else {
    cfFetchError = true;
  }
} catch {
  cfFetchError = true;
}

const bandAccentClasses = [
  'text-emerald-600 dark:text-emerald-400',
  'text-blue-600 dark:text-blue-400',
  'text-amber-600 dark:text-amber-400',
  'text-orange-600 dark:text-orange-400',
  'text-violet-600 dark:text-violet-400',
  'text-rose-600 dark:text-rose-400',
];

const bandTagClasses = [
  'bg-emerald-500/8 text-emerald-700 border-emerald-500/20 dark:text-emerald-300',
  'bg-blue-500/8 text-blue-700 border-blue-500/20 dark:text-blue-300',
  'bg-amber-500/8 text-amber-700 border-amber-500/20 dark:text-amber-300',
  'bg-orange-500/8 text-orange-700 border-orange-500/20 dark:text-orange-300',
  'bg-violet-500/8 text-violet-700 border-violet-500/20 dark:text-violet-300',
  'bg-rose-500/8 text-rose-700 border-rose-500/20 dark:text-rose-300',
];
---

<Base
  title="CP Journal — Shahed Ali"
  description="My competitive programming journey — problems solved on Codeforces, LeetCode, AtCoder and more."
>
  <div class="max-w-3xl mx-auto px-6 py-16">

    <div class="mb-12 opacity-0 animate-fade-up" style="animation-fill-mode: forwards;">
      <h1 class="text-[28px] sm:text-[34px] font-medium tracking-tight text-ink mb-3">CP Journal</h1>
      <p class="text-[14px] text-ink-muted leading-relaxed">
        Every problem I've solved, with my approach, thinking, and code. {problems.length} problems and counting.
      </p>
    </div>

    <div class="mb-6">
      <span class="text-[11px] uppercase tracking-widest font-medium text-ink-faint">Platforms</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-16 stagger">
      {Object.entries(platformMap).map(([platform, probs]) => (
        <a
          href={'/cp/' + platform.toLowerCase()}
          class="reveal group flex items-center justify-between p-5 rounded-xl border border-border hover:border-ink-muted bg-surface hover:bg-surface-secondary transition-all duration-200"
        >
          <div class="flex items-center gap-3">
            <span class={`w-9 h-9 rounded-lg flex items-center justify-center text-base font-mono ${platformColors[platform]}`}>
              {platformIcons[platform]}
            </span>
            <div>
              <div class="text-[14px] font-medium text-ink">{platform}</div>
              <div class="text-[12px] text-ink-faint mt-0.5">{probs.length} problem{probs.length !== 1 ? 's' : ''} solved</div>
            </div>
          </div>
          <svg class="w-3.5 h-3.5 text-ink-faint group-hover:text-ink group-hover:translate-x-0.5 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

    <div class="mb-6">
      <span class="text-[11px] uppercase tracking-widest font-medium text-ink-faint">Browse by tag</span>
    </div>
    <div class="reveal flex flex-wrap gap-2 mb-16">
      {sortedTags.map(([tag, count]) => (
        <a
          href={'/cp/tags/' + tag}
          class="inline-flex items-center gap-1.5 text-[12px] px-3 py-1.5 border border-border rounded-md text-ink-muted hover:text-ink hover:border-ink-muted transition-all"
        >
          #{tag}
          <span class="text-[11px] text-ink-faint">{count}</span>
        </a>
      ))}
    </div>

    {!cfFetchError && cfBands.length > 0 && (
      <div class="reveal">
        <div class="mb-6">
          <span class="text-[11px] uppercase tracking-widest font-medium text-ink-faint">Codeforces — topics by rating</span>
        </div>
        <div class="space-y-8">
          {cfBands.map((band, idx) => (
            <div>
              <div class="flex items-baseline gap-2 mb-3">
                <span class={`text-[13px] font-medium ${bandAccentClasses[idx]}`}>
                  {band.label}
                </span>
                <span class="text-[11px] text-ink-faint">{band.count} problems</span>
              </div>
              <div class="flex flex-wrap gap-2">
                {band.tags.map(tag => (
                  <span
                    class={`inline-flex items-center gap-1.5 text-[11px] px-2.5 py-1 rounded-md border ${bandTagClasses[idx]}`}
                    style={`opacity: ${tag.weight}`}
                  >
                    {tag.name}
                    <span class="opacity-60">{tag.count}</span>
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</Base>