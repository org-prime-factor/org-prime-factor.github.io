---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const works = [
  {
    name: "Bliss-NXT · Uber",
    period: "Sep 2024 – Present",
    role: "Software Engineer (Contract via Accenture)",
    desc: "Internal customer support platform used by 30+ global teams. Shipped compliance-critical features, large-scale migrations, and platform integrations — mostly as the sole engineer on each.",
    tags: ["React", "TypeScript", "GraphQL", "Apollo"],
    logo: "/logos/uber.jpeg",
    link: "/work/uber",
    highlights: [
      "HCV Bulk Comms & Vouchers",
      "ONDC / IGM 1.0",
      "CF/DF Fare Migration",
      "20+ Visual Identifiers",
    ],
  },
  {
    name: "BeyondScale Technologies",
    period: "Jan 2022 – Aug 2024",
    role: "Full-Stack Developer",
    desc: "Built across 5 client projects — citizen-scale government portals serving millions, US real estate data platforms, fintech backend, and file infrastructure. Full ownership from DB to UI.",
    tags: ["React", "Node.js", "Next.js", "PostgreSQL", "AWS"],
    logo: "/logos/beyondscale.jpeg",
    link: "/work/beyondscale",
    highlights: [
      "GSWS Govt. Portals",
      "Weiss Analytics",
      "FingoIndia",
      "Kiwibar.com",
    ],
  },
];

const TAG_COLORS: Record<string, string> = {
  React: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  JavaScript: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
  TypeScript: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  Algorithms: "bg-violet-500/10 text-violet-600 dark:text-violet-400",
  GraphQL: "bg-pink-500/10 text-pink-600 dark:text-pink-400",
  Discipline: "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400",
};

function tagColor(tag: string) {
  return TAG_COLORS[tag] ?? "bg-surface-secondary text-ink-muted";
}

const stack = [
  "Javascript",
  "TypeScript",
  "React.js",
  "Next.js",
  "Node.js",
  "REST",
  "GraphQL",
  "Apollo",
  "PostgreSQL",
  "AWS",
  "Tailwind CSS",
];
---

<Base>
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <div
      class="inline-flex items-center gap-2 text-[11px] font-medium uppercase tracking-widest text-emerald-600 dark:text-emerald-400 mb-8 opacity-0 animate-fade-in"
      style="animation-delay: 0ms; animation-fill-mode: forwards;"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
      ></span>
      Open to opportunities · Bangalore, India
    </div>

    <h1
      class="text-[38px] sm:text-[52px] font-medium leading-[1.1] tracking-tight text-ink mb-6 opacity-0 animate-fade-up"
      style="animation-delay: 80ms; animation-fill-mode: forwards;"
    >
      Software engineer<br />
      who <span class="text-accent">ships real things</span><br />
      and writes about it.
    </h1>

    <p
      class="text-[15px] text-ink-muted leading-relaxed max-w-[540px] mb-8 opacity-0 animate-fade-up"
      style="animation-delay: 160ms; animation-fill-mode: forwards;"
    >
      4+ years building across the stack — React, TypeScript, Node.js, GraphQL.
      Currently deep in frontend at Uber, shipping features used by support
      teams across 30+ countries.
    </p>

    <div
      class="flex items-center gap-3 flex-wrap opacity-0 animate-fade-up"
      style="animation-delay: 240ms; animation-fill-mode: forwards;"
    >
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-[13px] px-4 py-2 bg-ink text-surface rounded-lg hover:bg-ink/90 transition-colors font-medium"
      >
        Read the blog
      </a>
      <a
        href="#work"
        class="inline-flex items-center gap-2 text-[13px] px-4 py-2 border border-border rounded-lg text-ink-muted hover:text-ink hover:border-ink-muted transition-all"
      >
        See my work
      </a>
    </div>

    <!-- Stats -->
    <div
      class="flex items-center gap-8 mt-14 pt-8 border-t border-border opacity-0 animate-fade-up"
      style="animation-delay: 320ms; animation-fill-mode: forwards;"
    >
      {
        [
          { num: "4+", label: "Years experience" },
          { num: "30+", label: "Teams served at Uber" },
          { num: "5", label: "Client projects at BeyondScale" },
        ].map((stat) => (
          <div>
            <div class="text-[22px] font-medium tracking-tight text-ink">
              {stat.num}
            </div>
            <div class="text-[12px] text-ink-faint mt-0.5">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="border-t border-border">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <div class="mb-8">
        <span
          class="text-[11px] uppercase tracking-widest font-medium text-ink-faint"
          >Work</span
        >
      </div>

      <div class="flex flex-col gap-4">
        {
          works.map((w) => (
            <a
              href={w.link}
              class="reveal group flex flex-col sm:flex-row gap-5 p-6 rounded-xl border border-border hover:border-ink-muted bg-surface hover:bg-surface-secondary transition-all duration-200"
            >
              <div class="flex-1 min-w-0">
                <div class="flex items-start gap-3 mb-3">
                  <img
                    src={w.logo}
                    alt={w.name}
                    class="w-9 h-9 shrink-0 rounded-lg object-cover mt-0.5"
                  />
                  <div>
                    <div class="text-[15px] font-medium text-ink leading-tight">
                      {w.name}
                    </div>
                    <div class="text-[12px] text-ink-faint mt-0.5">
                      {w.role} · {w.period}
                    </div>
                  </div>
                </div>
                <p class="text-[13px] text-ink-muted leading-relaxed mb-4 max-w-lg">
                  {w.desc}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {w.tags.map((tag) => (
                    <span class="text-[11px] px-2 py-0.5 bg-surface-secondary rounded text-ink-faint border border-border">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <div class="shrink-0 sm:w-48 flex flex-col gap-2">
                <div class="text-[10px] uppercase tracking-widest text-ink-faint mb-1">
                  Shipped
                </div>
                {w.highlights.map((h) => (
                  <div class="text-[12px] text-ink-muted flex items-center gap-2">
                    <span class="w-1 h-1 rounded-full bg-ink-faint shrink-0" />
                    {h}
                  </div>
                ))}
                <div class="mt-4 inline-flex items-center gap-1.5 text-[12px] text-accent group-hover:gap-2.5 transition-all">
                  Full details
                  <svg
                    class="w-3 h-3"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="border-t border-border">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <div class="flex items-center justify-between mb-8">
        <span
          class="text-[11px] uppercase tracking-widest font-medium text-ink-faint"
          >From the blog</span
        >
        <a
          href="/blog"
          class="text-[12px] text-ink-muted hover:text-ink transition-colors group inline-flex items-center gap-1"
        >
          All posts
          <svg
            class="w-3 h-3 group-hover:translate-x-0.5 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="divide-y divide-border">
        {
          posts.map((post) => {
            const date = new Intl.DateTimeFormat("en-GB", {
              month: "short",
              year: "numeric",
            }).format(post.data.date);
            const tag = post.data.tags[0];
            return (
              <a
                href={`/blog/${post.slug}`}
                class="reveal group flex items-start justify-between gap-6 py-5 hover:bg-surface-secondary -mx-3 px-3 rounded-lg transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    {tag && (
                      <span
                        class={`text-[10px] font-medium uppercase tracking-wider px-2 py-0.5 rounded ${tagColor(tag)}`}
                      >
                        {tag}
                      </span>
                    )}
                    <span class="text-[12px] text-ink-faint">{date}</span>
                  </div>
                  <div class="text-[14px] font-medium text-ink leading-snug mb-1 group-hover:text-accent transition-colors">
                    {post.data.title}
                  </div>
                  <div class="text-[12px] text-ink-muted leading-relaxed line-clamp-1">
                    {post.data.description}
                  </div>
                </div>
                <div class="text-[11px] text-ink-faint shrink-0 pt-0.5">
                  {post.data.readTime ?? "5 min"}
                </div>
              </a>
            );
          })
        }
      </div>

      {
        posts.length === 0 && (
          <p class="text-[13px] text-ink-faint py-8">
            No posts yet — first one coming soon.
          </p>
        )
      }
    </div>
  </section>

  <!-- About -->
  <section id="about" class="border-t border-border">
    <div
      class="max-w-3xl mx-auto px-6 py-16 grid grid-cols-1 sm:grid-cols-2 gap-12"
    >
      <div class="reveal">
        <span
          class="text-[11px] uppercase tracking-widest font-medium text-ink-faint block mb-6"
          >About</span
        >
        <p class="text-[14px] text-ink-muted leading-relaxed mb-4">
          Software engineer based in Bangalore with 4+ years across the stack.
          Started full-stack at BeyondScale — built government portals serving
          millions, fintech systems, US real estate platforms. Now focused deep
          in frontend at Uber, shipping on Bliss-NXT used by support teams
          globally.
        </p>
        <p class="text-[14px] text-ink-muted leading-relaxed mb-4">
          I care about code that actually ships and actually works. I write
          about things I've had to figure out — debugging sessions, patterns
          that clicked, decisions that mattered.
        </p>
        <p class="text-[14px] text-ink-muted leading-relaxed">
          Outside work: LeetCode, self-discipline challenges, and occasionally
          reading things unrelated to tech.
        </p>
      </div>

      <div class="reveal">
        <span
          class="text-[11px] uppercase tracking-widest font-medium text-ink-faint block mb-6"
          >Stack</span
        >
        <div class="flex flex-wrap gap-2">
          {
            stack.map((item) => (
              <span class="text-[12px] px-3 py-1.5 border border-border rounded-md text-ink-muted hover:border-ink-muted hover:text-ink transition-all cursor-default">
                {item}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Base>
